# 🗺️ خطة n8n التفصيلية الكاملة — CRM أفروتك

## ما تم بناؤه (الموجود حالياً في Workflow)

| الـ Node | الوظيفة | الحالة |
|---|---|---|
| `Webhook1` (path: `messenger`) | استقبال رسائل فيسبوك | ✅ موجود |
| `Smart Router Input1` | تجميع بيانات الرسالة (sessionId, chatInput) | ✅ موجود |
| `AI Agent4` (qwen3-32b) | تصنيف الرسالة → GENERAL_INFO, DEEP_INFO.. إلخ | ✅ موجود |
| `Switch6` | توجيه الرد حسب التصنيف (11 فرع) | ✅ موجود |
| `Execute a SQL query19` | جلب كورسات ورشات نشطة للـ GENERAL_INFO | ✅ موجود |
| `Pre Deep Info1` | قائمة برامج للـ DEEP_INFO لاختيار منها | ✅ موجود |
| `Deep Course Info1` | تفاصيل كورس محدد | ✅ موجود |
| `Code in JavaScript 26-28` | Prompts للمنصة الأونلاين، الموقع، الدعم الفني | ✅ موجود |
| `AI Agent5` | رد على الـ DEEP_INFO | ✅ موجود |
| `HTTP Request16` | إرسال الرد عبر Messenger API | ✅ موجود |

## ما لم يُبنَ بعد (الخطوات المطلوبة)

> [!IMPORTANT]
> 3 SQL statements يجب تنفيذها أولاً في قاعدة البيانات قبل البدء في n8n

---

## خطوة 0 — تنفيذ SQL في قاعدة البيانات أولاً

```sql
-- 1. إضافة حقول crm_tickets
ALTER TABLE crm_tickets
  ADD COLUMN sales_level_id       int(11) DEFAULT NULL,
  ADD COLUMN running_program_id   int(11) DEFAULT NULL,
  ADD COLUMN running_program_type enum('Course','Workshop') DEFAULT NULL;

-- 2. إصلاح crm_ticket_messages
ALTER TABLE crm_ticket_messages
  MODIFY facebook_comment_id  int(11) DEFAULT NULL,
  MODIFY facebook_message_id  int(11) DEFAULT NULL,
  MODIFY instagram_message_id int(11) DEFAULT NULL,
  MODIFY instagram_comment_id int(11) DEFAULT NULL,
  MODIFY tiktok_comment_id    int(11) DEFAULT NULL,
  MODIFY tiktok_message_id    int(11) DEFAULT NULL,
  MODIFY whatsapp_message_id  int(11) DEFAULT NULL,
  MODIFY telegram_message_id  int(11) DEFAULT NULL,
  MODIFY linkedin_comment_id  int(11) DEFAULT NULL,
  MODIFY linkedin_message_id  int(11) DEFAULT NULL,
  MODIFY `pstn_call _id`      int(11) DEFAULT NULL,
  MODIFY pstn_sms_id          int(11) DEFAULT NULL,
  MODIFY topic_chat_id        int(11) DEFAULT NULL,
  ADD COLUMN router_value varchar(50) DEFAULT NULL,
  ADD COLUMN message_text  text        DEFAULT NULL,
  ADD COLUMN sender_type   enum('customer','bot','human') DEFAULT 'customer';

-- 3. ربط Lead بالمستخدم
ALTER TABLE crm_leads ADD COLUMN user_id_fk int(11) DEFAULT NULL;

-- 4. إضافة إعدادات Timer
INSERT INTO atc_config (title, value, comment) VALUES
  ('crm_pre_sale_timer_minutes',  '1435', '23h55m للمبيعات'),
  ('crm_complaint_timer_minutes', '240',  '4h للشكاوى'),
  ('crm_technical_timer_minutes', '240',  '4h للدعم الفني'),
  ('crm_followup_timer_minutes',  '1435', '23h55m المتابعة التالية');

-- 5. جدول Timers
CREATE TABLE IF NOT EXISTS crm_ticket_timers (
  id            int(11) NOT NULL AUTO_INCREMENT,
  crm_ticket_id int(11) NOT NULL,
  timer_type    enum('PRE_SALE_FOLLOWUP','POST_SALE_FOLLOWUP',
                     'TECHNICAL_SUPPORT_FOLLOWUP','COMPLAINT_FOLLOWUP') NOT NULL,
  sequence_no   tinyint(3) DEFAULT 1,
  scheduled_at  timestamp NOT NULL,
  executed_at   timestamp NULL DEFAULT NULL,
  status        enum('pending','executed','cancelled','skipped') DEFAULT 'pending',
  created       timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (id),
  KEY idx_due    (scheduled_at, status),
  KEY idx_ticket (crm_ticket_id),
  CONSTRAINT fk_timer_ticket FOREIGN KEY (crm_ticket_id)
    REFERENCES crm_tickets(id) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
```

